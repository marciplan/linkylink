// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BundelType {
  NORMAL
  YEAR_REVIEW
}

enum CategoryType {
  BEST
  WORST
}

model User {
  id                        String                    @id @default(cuid())
  email                     String                    @unique
  username                  String                    @unique
  password                  String
  name                      String?
  image                     String?
  linkylinks                LinkLink[]
  dismissedRecommendations  DismissedRecommendation[]
  comments                  Comment[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model LinkLink {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug          String      @unique
  title         String
  subtitle      String?
  avatar        String?
  headerImage   String?
  headerPrompt  String?
  headerImages  String[]
  links         Link[]
  type          BundelType  @default(NORMAL)
  year          Int?
  categories    Category[]
  views         Int         @default(0)
  isPublic      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Link {
  id                        String                    @id @default(cuid())
  linkylinkId               String
  linkylink                 LinkLink                  @relation(fields: [linkylinkId], references: [id], onDelete: Cascade)
  title                     String
  url                       String
  favicon                   String?
  context                   String?
  order                     Int
  clicks                    Int                       @default(0)
  likes                     Int                       @default(0)
  createdAt                 DateTime                  @default(now())
  dismissedRecommendations  DismissedRecommendation[]
  comments                  Comment[]
}

model DismissedRecommendation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, linkId])
  @@index([userId])
}

model Category {
  id            String       @id @default(cuid())
  linkylinkId   String
  linkylink     LinkLink     @relation(fields: [linkylinkId], references: [id], onDelete: Cascade)
  name          String
  icon          String       @default("Star")
  categoryType  CategoryType @default(BEST)
  order         Int
  rankLimit     Int          @default(5)
  items         CategoryItem[]
  createdAt     DateTime     @default(now())

  @@index([linkylinkId])
}

model CategoryItem {
  id          String    @id @default(cuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String
  url         String
  favicon     String?
  context     String?
  rank        Int
  clicks      Int       @default(0)
  likes       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([categoryId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([userId])
}